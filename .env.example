# Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=123456789:replace-me

# Optional instance name. Leave unset or use default for the primary gateway.
# Named instances use separate env/state/log/LaunchAgent/tmux names.
# CODEX_TELEGRAM_INSTANCE=tools

# The single Telegram chat ID allowed to control the gateway.
# Get it from a received update or a bot like @userinfobot.
TELEGRAM_OWNER_CHAT_ID=123456789

# tmux target for the persistent Codex session.
COD_TELEGRAM_TMUX_TARGET=codex:0.0
COD_TELEGRAM_TMUX_REQUIRE_COMMAND=codex

# Codex runtime mode used by start_codex_telegram_session.sh.
# yolo: danger-full-access + never ask
# stark: workspace-write + on-request approvals
# read-only: read-only + on-request approvals
# custom: use CODEX_SANDBOX and CODEX_APPROVAL_POLICY below
CODEX_TELEGRAM_CODEX_MODE=stark
# CODEX_SANDBOX=workspace-write
# CODEX_APPROVAL_POLICY=on-request

# tmux key sequences for Telegram approval buttons.
# Comma-separated tmux send-keys tokens.
COD_TELEGRAM_APPROVE_KEYS=C-m
COD_TELEGRAM_APPROVE_SESSION_KEYS=Right,C-m
COD_TELEGRAM_DENY_KEYS=Escape

# Keep Telegram's typing indicator alive while Codex is preparing a reply.
# Telegram typing status is temporary, so the gateway refreshes it periodically.
COD_TELEGRAM_TYPING_KEEPALIVE_SECONDS=600
COD_TELEGRAM_TYPING_INTERVAL_SECONDS=4
