#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REGISTRY="${CODEX_TELEGRAM_REGISTRY:-${ROOT}/codex_telegram_instances.json}"
PYTHON="${PYTHON:-$(command -v python3 || true)}"
GATEWAY="${ROOT}/COD_telegram_gateway.py"
LAUNCHER="${ROOT}/start_codex_telegram_session.sh"

if [[ -z "${PYTHON}" ]]; then
  echo "python3 was not found. Set PYTHON=/path/to/python3 or add python3 to PATH." >&2
  exit 1
fi

usage() {
  cat <<'EOF'
Usage:
  ./codex-telegram add NAME --token TOKEN --chat-id CHAT_ID [--mode stark|yolo|read-only] [--workdir PATH]
  ./codex-telegram list
  ./codex-telegram start NAME [--attach]
  ./codex-telegram restart NAME [--attach]
  ./codex-telegram start-all
  ./codex-telegram status [NAME]
  ./codex-telegram send NAME [--parse-mode MarkdownV2|HTML] "message"
  ./codex-telegram stop NAME

Examples:
  ./codex-telegram add tools --token '123:abc' --chat-id '123456789'
  ./codex-telegram restart tools
  ./codex-telegram status tools
EOF
}

normalize_name() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9_-]+/-/g; s/^[-_]+//; s/[-_]+$//'
}

write_env() {
  local name="$1"
  local token="$2"
  local chat_id="$3"
  local mode="$4"
  local workdir="$5"
  local env_file="${ROOT}/.env.codex-telegram"
  local session="codex"
  if [[ "${name}" != "default" ]]; then
    env_file="${ROOT}/.env.codex-telegram-${name}"
    session="codex-${name}"
  fi

  umask 077
  {
    echo "TELEGRAM_BOT_TOKEN=${token}"
    echo "TELEGRAM_OWNER_CHAT_ID=${chat_id}"
    echo "CODEX_TELEGRAM_INSTANCE=${name}"
    echo "CODEX_TELEGRAM_CODEX_MODE=${mode}"
    echo "CODEX_TELEGRAM_CODEX_WORKDIR=${workdir}"
    echo "COD_TELEGRAM_TMUX_TARGET=${session}:0.0"
    echo "COD_TELEGRAM_TMUX_REQUIRE_COMMAND=codex"
    echo "COD_TELEGRAM_SUBMIT_KEYS=C-m,C-m"
    echo "COD_TELEGRAM_TYPING_KEEPALIVE_SECONDS=600"
    echo "COD_TELEGRAM_TYPING_INTERVAL_SECONDS=4"
  } > "${env_file}"
  chmod 600 "${env_file}"
}

registry_py() {
  "${PYTHON}" - "$REGISTRY" "$@"
}

cmd="${1:-}"
if [[ -z "${cmd}" ]]; then
  usage
  exit 1
fi
shift || true

case "${cmd}" in
  add)
    name="$(normalize_name "${1:-}")"
    if [[ -z "${name}" ]]; then
      echo "Missing NAME." >&2
      usage
      exit 1
    fi
    shift
    token=""
    chat_id=""
    mode="stark"
    workdir="${HOME}"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --token)
          token="${2:?Missing value for --token}"
          shift 2
          ;;
        --token=*)
          token="${1#--token=}"
          shift
          ;;
        --chat-id)
          chat_id="${2:?Missing value for --chat-id}"
          shift 2
          ;;
        --chat-id=*)
          chat_id="${1#--chat-id=}"
          shift
          ;;
        --mode)
          mode="${2:?Missing value for --mode}"
          shift 2
          ;;
        --mode=*)
          mode="${1#--mode=}"
          shift
          ;;
        --workdir)
          workdir="${2:?Missing value for --workdir}"
          shift 2
          ;;
        --workdir=*)
          workdir="${1#--workdir=}"
          shift
          ;;
        *)
          echo "Unknown add argument: $1" >&2
          exit 1
          ;;
      esac
    done
    if [[ -z "${token}" || -z "${chat_id}" ]]; then
      echo "add requires --token and --chat-id." >&2
      exit 1
    fi
    write_env "${name}" "${token}" "${chat_id}" "${mode}" "${workdir}"
    registry_py add "${name}" "${mode}" "${workdir}" <<'PY'
import json
import sys
from pathlib import Path

registry = Path(sys.argv[1])
name = sys.argv[3]
mode = sys.argv[4]
workdir = sys.argv[5]
try:
    data = json.loads(registry.read_text())
except FileNotFoundError:
    data = {"instances": {}}
data.setdefault("instances", {})[name] = {"mode": mode, "workdir": workdir}
registry.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n")
PY
    chmod 600 "${REGISTRY}"
    echo "Registered instance ${name}."
    ;;

  list)
    registry_py list <<'PY'
import json
import sys
from pathlib import Path

registry = Path(sys.argv[1])
try:
    data = json.loads(registry.read_text())
except FileNotFoundError:
    data = {"instances": {}}
instances = data.get("instances", {})
if not instances:
    print("No saved instances.")
else:
    for name, config in sorted(instances.items()):
        print(f"{name}\tmode={config.get('mode', 'stark')}\tworkdir={config.get('workdir', '')}")
PY
    ;;

  start)
    name="$(normalize_name "${1:-}")"
    if [[ -z "${name}" ]]; then
      echo "Missing NAME." >&2
      exit 1
    fi
    shift || true
    if [[ "${1:-}" == "--attach" ]]; then
      exec "${LAUNCHER}" --instance "${name}"
    fi
    "${LAUNCHER}" --instance "${name}" --no-attach
    ;;

  restart)
    name="$(normalize_name "${1:-}")"
    if [[ -z "${name}" ]]; then
      echo "Missing NAME." >&2
      exit 1
    fi
    shift || true
    CODEX_TELEGRAM_INSTANCE="${name}" "${PYTHON}" "${GATEWAY}" stop-gateway 2>/dev/null || true
    session="codex"
    if [[ "${name}" != "default" ]]; then
      session="codex-${name}"
    fi
    tmux kill-session -t "${session}" 2>/dev/null || true
    if [[ "${1:-}" == "--attach" ]]; then
      exec "${LAUNCHER}" --instance "${name}"
    fi
    "${LAUNCHER}" --instance "${name}" --no-attach
    ;;

  start-all)
    registry_py start_all "${LAUNCHER}" <<'PY'
import json
import subprocess
import sys
from pathlib import Path

registry = Path(sys.argv[1])
launcher = sys.argv[3]
try:
    data = json.loads(registry.read_text())
except FileNotFoundError:
    raise SystemExit("No saved instances.")
instances = sorted((data.get("instances") or {}).keys())
if not instances:
    raise SystemExit("No saved instances.")
for name in instances:
    subprocess.run([launcher, "--instance", name, "--no-attach"], check=True)
PY
    ;;

  status)
    name="$(normalize_name "${1:-default}")"
    if [[ "${name}" == "default" ]]; then
      "${PYTHON}" "${GATEWAY}" status
    else
      CODEX_TELEGRAM_INSTANCE="${name}" "${PYTHON}" "${GATEWAY}" status
    fi
    ;;

  send)
    name="$(normalize_name "${1:-}")"
    if [[ -z "${name}" ]]; then
      echo "Missing NAME." >&2
      exit 1
    fi
    shift
    parse_mode=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --parse-mode)
          parse_mode="${2:?Missing value for --parse-mode}"
          shift 2
          ;;
        --parse-mode=*)
          parse_mode="${1#--parse-mode=}"
          shift
          ;;
        *)
          break
          ;;
      esac
    done
    if [[ $# -lt 1 ]]; then
      echo "Missing message." >&2
      exit 1
    fi
    if [[ -n "${parse_mode}" ]]; then
      CODEX_TELEGRAM_INSTANCE="${name}" "${PYTHON}" "${GATEWAY}" send --parse-mode "${parse_mode}" "$*"
    else
      CODEX_TELEGRAM_INSTANCE="${name}" "${PYTHON}" "${GATEWAY}" send "$*"
    fi
    ;;

  stop)
    name="$(normalize_name "${1:-}")"
    if [[ -z "${name}" ]]; then
      echo "Missing NAME." >&2
      exit 1
    fi
    CODEX_TELEGRAM_INSTANCE="${name}" "${PYTHON}" "${GATEWAY}" stop-gateway
    ;;

  --help|-h|help)
    usage
    ;;

  *)
    echo "Unknown command: ${cmd}" >&2
    usage
    exit 1
    ;;
esac
